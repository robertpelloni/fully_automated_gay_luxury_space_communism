# AI Hustle Machine — Environment Configuration
# Copy this file to .env and fill in values

# ═══════════════════════════════════════════════════
# LLM Configuration (Required for Agent Mode)
# ═══════════════════════════════════════════════════

# Base URL for OpenAI-compatible LLM server
# LM Studio default: http://localhost:1234/v1
# Ollama default: http://localhost:11434/v1
# OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=http://localhost:1234/v1

# Model name (leave empty to auto-detect from server)
# Examples: gemma-4-26b-it, qwen3:27b, claude-3-sonnet
LLM_MODEL=

# API key (not needed for local LM Studio or Ollama)
LLM_API_KEY=

# ═══════════════════════════════════════════════════
# Embedding Configuration (Optional — for vector search)
# ═══════════════════════════════════════════════════

# Embedding server URL (usually same as LLM)
EMBED_BASE_URL=http://localhost:1234/v1

# Embedding model name (leave empty to auto-detect)
# Example: text-embedding-nomic-embed-text-v1.5
EMBED_MODEL=

# ═══════════════════════════════════════════════════
# Hustle-Specific API Keys
# ═══════════════════════════════════════════════════

# Tavily — for real web search in Research hustle
# Get one at: https://tavily.com
TAVILY_API_KEY=

# Anthropic — for Claude in the LLM waterfall
ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════
# Social Media (Future — not yet wired)
# ═══════════════════════════════════════════════════

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
